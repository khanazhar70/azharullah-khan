{% comment %}
  Custom grid Section with modal popu and add to cart
{% endcomment %}
<script src="{{ 'product-custom-grid.js' | asset_url }}" defer="defer"></script>
{% style %}
  .custom-grid-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;

  }
{% endstyle %}

<section class="product_grid_custom custom-grid-{{ section.id }}-padding">
  <div class="page-width">
    <div class="product_grid_header">
      <h2>{{ section.settings.inline }}</h2>
    </div>
    <div class="product_grid_wrapper">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        <div
          class="product_grid_item"
          product-data-id="{{ product.id }}"
          product-data-handle="{{ product.handle }}"
          data-variants="{{ product.variants | json |escape }}"
          onclick="openProductPopup({{ product.id }})"
        >
          <img src="{{ product.featured_image | image_url: width:3450 }}" alt="" width="" height="">
        </div>
        {% render 'product-info-popup', product: product %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Custom Grid",
  "max_blocks": 6,
  "settings": [

    {
  "type": "inline_richtext",
  "id": "inline",
  "default": "Section Title",
  "label": "Section Title"
},
     {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks":[
    {
      "type":"product",
      "name":"product",
      "settings":[
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Custom Grid"
    }
  ]
}
{% endschema %}
