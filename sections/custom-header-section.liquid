{% comment %}
  Custom Header Section with Mobile Toggle Navigation
{% endcomment %}
<script src="{{ 'custom-header-section.js' | asset_url }}" defer="defer"></script>

{% style %}
                   .custom-header-{{ section.id }}-padding {
                     padding-top: {{ section.settings.padding_top }}px;
                     padding-bottom: {{ section.settings.padding_bottom }}px;

                   }
  .custom-header-{{ section.id }}-bg{
    background:{{section.settings.background_color}};
  }
{% endstyle %}

<!-- Header Section HTML Structure -->
<header class="custom-header-{{ section.id }}-padding custom-header-{{ section.id }}-bg">
  <div class="page-width">
    <div class="custom_header_wrapper">
      <!-- Mobile navigation toggle button -->
      <button class="toggle_btn" id="mobileToggle">
        <img
          src="https://cdn.shopify.com/s/files/1/0689/3220/6774/files/hamburger.png?v=1748410493"
          class="hamburger_icon"
          alt="Open menu"
          width="18"
          height=""
        >
        <!-- Close icon - hidden by default -->
        <img
          src="https://cdn.shopify.com/s/files/1/0689/3220/6774/files/crossTime.png?v=1748410493"
          class="times_icon"
          alt="Close menu"
          width="18"
          height=""
        >
      </button>

      <!-- Site logo -->
      <a href="{{ routes.root_url }}" class="custom_header_logo">
        <img
          src="{{ section.settings.logo | image_url: width: 200, height: 200 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          height="auto"
        >
      </a>

      <!-- Header text content -->
      <div class="custom_header_text">{{ section.settings.paragraph }}</div>

      <!-- Primary action button -->
      <div class="right_grid_item">
        <a href="{{ section.settings.button_link }}" class="btn primary_btn_yellow">
          {{ section.settings.button_title }}
          {% if section.settings.button_icon %}
            <img
              src="{{ section.settings.button_icon | image_url: width: 24 }}"
              alt="Button icon"
              width="24"
              height=""
              class="arrow_icon"
            >
          {% endif %}
        </a>
      </div>
    </div>

    <!-- Mobile navigation menu - hidden by default -->
    <nav class="navbar-items" id="mobileNav">
      <!-- Duplicate content for mobile navigation -->
      <div class="custom_header_text_mobile">{{ section.settings.paragraph }}</div>
      <a href="{{ section.settings.button_link }}" class="btn primary_btn_yellow">
        {{ section.settings.button_title }}
        {% if section.settings.button_icon %}
          <img
            src="{{ section.settings.button_icon | image_url: width: 24 }}"
            alt="Button icon"
            width=""
            height=""
            class="arrow_icon"
          >
        {% endif %}
      </a>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Custom Header",
  "enabled_on": {
   "groups": ["header"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 70,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 70
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Header Text"
    },
    {
      "type": "text",
      "id": "button_title",
      "label": "Button Text",
      "default": "button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F5F5F5"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}
